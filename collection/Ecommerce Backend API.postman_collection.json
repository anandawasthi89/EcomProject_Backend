{
  "info": {
    "_postman_id": "0d0ef691-bc31-44e5-a8b3-d684a90d7d6f",
    "name": "Ecommerce Backend API",
    "description": "Rerunnable Postman collection for the Spring Boot e-commerce backend API. Initializes unique test users on each run, exercises public and protected endpoints, covers negative cases, tests legacy aliases, and performs cleanup at the end.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 Setup And Health",
      "item": [
        {
          "name": "GET Root Health And Initialize Run Variables",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var seed = Date.now().toString();",
                  "pm.collectionVariables.set('runSeed', seed);",
                  "pm.collectionVariables.set('primaryEmail', 'alice+' + seed + '@example.com');",
                  "pm.collectionVariables.set('primaryPassword', 'password123');",
                  "pm.collectionVariables.set('primaryUpdatedEmail', 'alice.updated+' + seed + '@example.com');",
                  "pm.collectionVariables.set('primaryUpdatedPassword', 'newpassword123');",
                  "pm.collectionVariables.set('registeredEmail', 'bob+' + seed + '@example.com');",
                  "pm.collectionVariables.set('registeredPassword', 'password123');",
                  "pm.collectionVariables.set('registeredUpdatedEmail', 'bob.updated+' + seed + '@example.com');",
                  "pm.collectionVariables.set('aliasEmail', 'cara+' + seed + '@example.com');",
                  "pm.collectionVariables.set('aliasPassword', 'password123');",
                  "pm.collectionVariables.set('token', '');",
                  "pm.collectionVariables.set('legacyToken', '');",
                  "pm.collectionVariables.set('userId', '');",
                  "pm.collectionVariables.set('registeredUserId', '');",
                  "",
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Service health payload is valid', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.service).to.eql('ecommerce-backend');",
                  "    pm.expect(json.status).to.eql('ok');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                ""
              ]
            },
            "description": "Initializes fresh unique variables for the run and verifies that the API is reachable."
          },
          "response": []
        }
      ]
    },
    {
      "name": "02 Public User Onboarding",
      "item": [
        {
          "name": "POST Create User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('userId', String(json.id));",
                  "",
                  "pm.test('Created user payload contains id and expected email', function () {",
                  "    pm.expect(json.id).to.exist;",
                  "    pm.expect(json.email).to.eql(pm.collectionVariables.get('primaryEmail'));",
                  "});"
